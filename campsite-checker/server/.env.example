# Copy this to .env and fill in your values

PORT=3001

# Resend API key for email notifications (https://resend.com)
RESEND_API_KEY=re_your_key_here

# The "from" address for notification emails (must be verified in Resend)
EMAIL_FROM=CampWatch <noreply@yourdomain.com>

# Recreation.gov API key (free at https://ridb.recreation.gov)
RECREATION_GOV_API_KEY=your_key_here
